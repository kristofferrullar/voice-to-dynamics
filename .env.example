# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ── Azure Speech (STT + TTS) ──────────────────────────────────────────────────
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=swedencentral

# ── Azure OpenAI Real-time (Conversation Host) ────────────────────────────────
# NOTE: gpt-4o-realtime-preview quota is 0 on new subscriptions.
# Request increase at: https://aka.ms/oai/stuquotarequest
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_REALTIME_DEPLOYMENT=gpt-4o-realtime-preview

# ── Anthropic (Agent LLM + Conversation Host fallback) ────────────────────────
ANTHROPIC_API_KEY=

# ── GitHub MCP Server ─────────────────────────────────────────────────────────
# Create at https://github.com/settings/tokens (scopes: repo, issues, pull_requests)
GITHUB_PERSONAL_ACCESS_TOKEN=

# ── Microsoft Dataverse / Entra ID ───────────────────────────────────────────
# See docs/architecture.md § Azure Setup for how to obtain these values.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
DATAVERSE_ENVIRONMENT_URL=https://<org>.crm4.dynamics.com

# ── Microsoft Teams (Azure Bot Service) ──────────────────────────────────────
# 1. Create Azure Bot: az bot create --resource-group <rg> --name <bot> --kind registration
# 2. Set messaging endpoint: https://<your-tunnel>/webhook/teams
# 3. Add Teams channel in Azure Portal → Bot Service → Channels
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=

# ── Twilio (WhatsApp) ─────────────────────────────────────────────────────────
# 1. Create account at https://www.twilio.com
# 2. Activate WhatsApp sandbox or buy a WhatsApp-enabled number
# 3. Set webhook URL: https://<your-tunnel>/webhook/whatsapp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# ── Azure Communication Services (voice calls) ────────────────────────────────
# 1. Create ACS resource in Azure Portal and acquire a phone number
# 2. Register IncomingCall event to: https://<your-tunnel>/webhook/acs/call
# 3. ACS_CALLBACK_URL is your public HTTPS base URL (no trailing slash)
ACS_CONNECTION_STRING=
ACS_PHONE_NUMBER=
ACS_CALLBACK_URL=

# ── OpenClaw Gateway ──────────────────────────────────────────────────────────
# Random secret — must match OPENCLAW_GATEWAY_TOKEN in docker-compose.yml
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
OPENCLAW_GATEWAY_TOKEN=

# Optional: Azure model providers for OpenClaw agents
# Leave empty to use Anthropic models only
AZURE_OPENAI_API_KEY=
AZURE_FOUNDRY_API_KEY=
